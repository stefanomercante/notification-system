{
    "name": "stefanomercante/notification-system",
    "description": "Multi-channel notification system with queue processing",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Stefano Mercante",
            "email": "info@stefano-mercante.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "ext-pdo": "*",
        "ext-redis": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "NotificationSystem\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "NotificationSystem\\Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
